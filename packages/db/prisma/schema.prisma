generator client { provider = "prisma-client-js" }

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan { FREE PRO BUSINESS }
enum ProjectStatus { DRAFT UPLOADED QUEUED PROCESSING COMPLETED FAILED }
enum JobStatus { PENDING PROCESSING COMPLETED FAILED }
enum ExportFormat { TXT DOCX SRT }
enum BillingStatus { INACTIVE TRIALING ACTIVE PAST_DUE CANCELED }

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  fullName        String?
  plan            Plan              @default(FREE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  projects        Project[]
  usageEvents     UsageEvent[]
  billingCustomer BillingCustomer?
  apiKeys         ApiKey[]
}

model Project {
  id               String              @id @default(cuid())
  userId           String
  title            String
  sourceFilename   String?
  sourceMimeType   String?
  sourceUrl        String?
  storageKey       String?
  language         String?
  durationSec      Int?
  status           ProjectStatus       @default(DRAFT)
  provider         String?
  providerMetadata Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  lastEditedAt     DateTime?
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  segments         TranscriptSegment[]
  jobs             TranscriptionJob[]
  exports          Export[]
  sharedLinks      SharedProjectLink[]
  @@index([userId, createdAt])
}

model TranscriptionJob {
  id            String    @id @default(cuid())
  projectId     String
  provider      String
  providerJobId String?
  status        JobStatus @default(PENDING)
  errorMessage  String?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId, status])
}

model TranscriptSegment {
  id           String   @id @default(cuid())
  projectId    String
  startMs      Int
  endMs        Int
  speaker      String?
  text         String
  confidence   Float?
  orderIndex   Int
  isEdited     Boolean  @default(false)
  originalText String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId, orderIndex])
}

model Export {
  id        String       @id @default(cuid())
  projectId String
  format    ExportFormat
  url       String
  createdAt DateTime     @default(now())
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId, createdAt])
}

model BillingCustomer {
  id                 String        @id @default(cuid())
  userId             String        @unique
  stripeCustomerId   String?       @unique
  status             BillingStatus @default(INACTIVE)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageEvent {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  type      String
  value     Int
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, type, createdAt])
  @@index([projectId, createdAt])
}

model ApiKey {
  id         String   @id @default(cuid())
  userId     String
  label      String
  keyPrefix  String
  keyHash    String   @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
}

model SharedProjectLink {
  id        String   @id @default(cuid())
  projectId String
  token     String   @unique
  expiresAt DateTime?
  createdAt DateTime @default(now())
  revokedAt DateTime?
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId, createdAt])
}
