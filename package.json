{
  "name": "transcribe-pro",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @transcribe/db db:generate",
    "db:migrate": "pnpm --filter @transcribe/db db:migrate",
    "dev:web": "pnpm --filter web dev",
    "dev:worker": "pnpm --filter worker dev"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
